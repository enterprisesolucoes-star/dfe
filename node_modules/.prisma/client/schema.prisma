generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model bandeiras {
  id        Int     @id @default(autoincrement())
  tpag      String? @db.VarChar(2)
  tband_opc String? @db.VarChar(50)
  cnpj_opc  String? @db.VarChar(20)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model caixa_movimentos {
  id              Int                   @id @default(autoincrement())
  empresa_id      Int
  financeiro_id   Int?
  venda_id        Int?
  compra_id       Int?
  conta_id        Int
  tipo            caixa_movimentos_tipo
  valor           Decimal               @db.Decimal(15, 2)
  data_movimento  DateTime?             @default(now()) @db.Timestamp(0)
  forma_pagamento String?               @default("01") @db.VarChar(2)
  historico       String?               @db.VarChar(255)
  usuario_id      Int?

  @@index([conta_id], map: "idx_conta")
  @@index([empresa_id, data_movimento], map: "idx_empresa_data")
}

model caixas {
  id              Int            @id @default(autoincrement())
  usuario_id      Int
  nome_usuario    String?        @db.VarChar(100)
  data_abertura   DateTime       @db.DateTime(0)
  data_fechamento DateTime?      @db.DateTime(0)
  troco_inicial   Decimal?       @default(0.00) @db.Decimal(10, 2)
  total_vendas    Decimal?       @default(0.00) @db.Decimal(10, 2)
  status          caixas_status? @default(aberto)

  @@index([status], map: "idx_status")
  @@index([usuario_id], map: "idx_usuario")
}

model clientes {
  id                     Int       @id @default(autoincrement())
  nome                   String    @db.VarChar(255)
  documento              String?   @db.VarChar(18)
  email                  String?   @db.VarChar(255)
  telefone               String?   @db.VarChar(20)
  logradouro             String?   @db.VarChar(255)
  numero                 String?   @db.VarChar(10)
  complemento            String?   @db.VarChar(100)
  bairro                 String?   @db.VarChar(100)
  municipio              String?   @db.VarChar(100)
  codigo_municipio       String?   @db.VarChar(10)
  uf                     String?   @db.Char(2)
  cep                    String?   @db.VarChar(10)
  created_at             DateTime? @default(now()) @db.Timestamp(0)
  ativo                  Int?      @default(1) @db.TinyInt
  empresa_id             Int?
  ie                     String?   @db.VarChar(20)
  ind_ie_dest            String?   @default("9") @db.Char(1)
  regime_tributario      String?   @default("1") @db.Char(1)
  entidade_governamental String?   @default("0") @db.Char(1)
  indIEDest              String?   @default("9") @db.Char(1)

  @@index([empresa_id], map: "idx_empresa")
}

model compras {
  id                Int             @id @default(autoincrement())
  empresa_id        Int?
  fornecedor_id     Int?
  numero_nf         String?         @default("") @db.VarChar(60)
  data_entrada      DateTime        @db.Date
  chave_acesso      String?         @default("") @db.VarChar(44)
  natureza_operacao String?         @default("COMPRA DE MERCADORIA") @db.VarChar(100)
  valor_total       Decimal?        @default(0.00) @db.Decimal(12, 2)
  valor_desconto    Decimal?        @default(0.00) @db.Decimal(12, 2)
  valor_frete       Decimal?        @default(0.00) @db.Decimal(12, 2)
  observacoes       String?         @db.Text
  status            compras_status? @default(Confirmada)
  created_at        DateTime?       @default(now()) @db.Timestamp(0)
  compras_itens     compras_itens[]

  @@index([data_entrada], map: "idx_data")
  @@index([empresa_id], map: "idx_empresa")
}

model compras_itens {
  id             Int     @id @default(autoincrement())
  compra_id      Int
  produto_id     Int
  quantidade     Decimal @default(1.000) @db.Decimal(12, 3)
  valor_unitario Decimal @default(0.0000) @db.Decimal(12, 4)
  valor_total    Decimal @default(0.00) @db.Decimal(12, 2)
  compras        compras @relation(fields: [compra_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "compras_itens_ibfk_1")

  @@index([compra_id], map: "compra_id")
}

model contas_financeiras {
  id            Int                      @id @default(autoincrement())
  empresa_id    Int
  nome          String                   @db.VarChar(100)
